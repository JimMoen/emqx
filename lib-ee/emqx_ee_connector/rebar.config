%% -*- mode: erlang -*-
{erl_opts, [debug_info]}.
{deps, [
  {hstreamdb_erl, {git, "https://github.com/hstreamdb/hstreamdb_erl.git", {tag, "0.2.5"}}},
  %% {influxdb, {git, "https://github.com/emqx/influxdb-client-erl", {tag, "1.1.4"}}},
  {influxdb, {git, "https://github.com/JimMoen/influxdb-client-erl", {branch, "compatibility-v1-auth"}}},
  {emqx, {path, "../../apps/emqx"}}
]}.

{shell, [
    {apps, [emqx_ee_connector]}
]}.
